# Copia este archivo a .env y rellena los valores

# Claude API
ANTHROPIC_API_KEY=sk-ant-...

# CMS: "nextjs_api" (escribe MDX directamente) o "wordpress"
CMS_TYPE=nextjs_api

# Para nextjs_api: ruta absoluta al directorio content/ del proyecto
CMS_URL=../content

# Para WordPress: URL base del sitio
# CMS_URL=https://tu-sitio.com

# Token de autenticación (solo WordPress)
CMS_TOKEN=

# Supabase (cola de revisión compartida)
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_KEY=eyJhbGci...

# Máximo de artículos a generar por día
MAX_ARTICULOS_DIA=40
